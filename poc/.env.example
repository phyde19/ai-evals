# MLflow Chat POC — environment variables
# Copy to .env and fill in values, then: source .env && make start-mlflow

# ── Toggle ────────────────────────────────────────────────────────────────────
# Set to "true" to wire up real MLflow tracing to Databricks.
# Any other value (or unset) runs with mock UUIDs — no Databricks connection.
MLFLOW_ENABLED=false

# ── Databricks (required when MLFLOW_ENABLED=true) ────────────────────────────
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── MLflow experiment (optional) ──────────────────────────────────────────────
# Workspace path to the experiment. Created automatically if it doesn't exist.
MLFLOW_EXPERIMENT_NAME=/Shared/chat-poc

# Defaults to "databricks" — no need to change for Databricks-hosted MLflow.
# MLFLOW_TRACKING_URI=databricks

# ── Server (optional) ─────────────────────────────────────────────────────────
# PORT=8001
# HOST=127.0.0.1
